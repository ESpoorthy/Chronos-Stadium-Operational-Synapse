# ─── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_strong_postgres_password
POSTGRES_DB=chronos_db
DATABASE_URL=postgresql+asyncpg://your_postgres_user:your_strong_postgres_password@db:5432/chronos_db

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Authentication ────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_a_strong_random_secret_key_minimum_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── AI / API Keys ─────────────────────────────────────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Application ───────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:3000
# Set to "production" to enable HSTS and other production-only headers
ENVIRONMENT=development

# ─── Next.js ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
